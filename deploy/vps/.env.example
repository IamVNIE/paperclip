# -----------------------------------------------------------------------------
# Paperclip VPS deployment env — copy to .env in this directory
# -----------------------------------------------------------------------------

# Public URL the app is served at. Must match the host in Caddyfile exactly.
PAPERCLIP_PUBLIC_URL=https://yourpublicurl.com

# Neon Postgres — use the POOLER endpoint (host contains "-pooler").
# sslmode=require is mandatory. Neon requires TLS.
# Example: postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/paperclip?sslmode=require
DATABASE_URL=

# Better Auth signing secret.
# Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Secrets-at-rest master key (32 bytes, base64). Encrypts agent API keys etc.
# Generate: openssl rand -base64 32
# ROTATING THIS INVALIDATES EXISTING ENCRYPTED SECRETS — back up first.
PAPERCLIP_SECRETS_MASTER_KEY=

# Host directory bind-mounted into the container at /paperclip.
# Holds secrets master key file, agent workspaces, uploaded assets.
# Survives `docker compose down -v`. `make up` creates it if missing.
# Must be writable by the container user (UID 1000 by default).
PAPERCLIP_DATA_DIR=/home/ec2-user/paperclip-data

# Optional: pin the built image tag. Default "local" rebuilds from the checkout.
# PAPERCLIP_IMAGE_TAG=local

# Optional adapter API keys — prefer Paperclip secret refs instead of inline.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional: route Claude Code through an Anthropic-API-compatible provider
# (e.g. MiniMax). Leave all unset to use real api.anthropic.com.
#
# Example MiniMax values:
#   ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
#   ANTHROPIC_AUTH_TOKEN=<minimax-api-key>
#   ANTHROPIC_MODEL=MiniMax-M2.7
#   ANTHROPIC_SMALL_FAST_MODEL=MiniMax-M2.7
#   ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7
#   ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M2.7
#   ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7
#   API_TIMEOUT_MS=3000000
#   CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# ANTHROPIC_BASE_URL=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=
# ANTHROPIC_SMALL_FAST_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# API_TIMEOUT_MS=
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=
